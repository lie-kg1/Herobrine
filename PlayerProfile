import org.bukkit.inventory.ItemStack;
import org.bukkit.inventory.meta.SkullMeta;
import org.bukkit.profile.PlayerProfile;
import java.util.UUID;

// 1. Create the Player Head item
ItemStack herobrineHead = new ItemStack(org.bukkit.Material.PLAYER_HEAD);
SkullMeta headMeta = (SkullMeta) herobrineHead.getItemMeta();

if (headMeta != null) {
    // 2. Fetch the profile for the hardcoded Mojang Herobrine placeholder account
    PlayerProfile herobrineProfile = Bukkit.createPlayerProfile(UUID.fromString("f84c6a79-0a4e-45e0-879b-cd49ebd485a9"), "MHF_Herobrine");
    
    // 3. Apply the profile properties to the head metadata
    headMeta.setOwnerProfile(herobrineProfile);
    herobrineHead.setItemMeta(headMeta);
}

